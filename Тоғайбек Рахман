// ===== IMPORT =====
import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.web.bind.annotation.*;
import org.springframework.http.ResponseEntity;

import java.util.*;
import java.util.concurrent.atomic.AtomicLong;

// ===== MAIN =====
@SpringBootApplication
@RestController
@RequestMapping("/api")
public class ShopApiApplication {

    public static void main(String[] args) {
        SpringApplication.run(ShopApiApplication.class, args);
    }

    // ===== DATA (in-memory база) =====
    private List<User> users = new ArrayList<>();
    private List<Product> products = new ArrayList<>();
    private Map<String, Long> tokens = new HashMap<>();

    private AtomicLong userId = new AtomicLong();
    private AtomicLong productId = new AtomicLong();

    // ===== USER MODEL =====
    static class User {
        public Long id;
        public String email;
        public String password;

        public User(Long id, String email, String password) {
            this.id = id;
            this.email = email;
            this.password = password;
        }
    }

    // ===== PRODUCT MODEL =====
    static class Product {
        public Long id;
        public String name;
        public double price;
        public String description;
        public Long userId;

        public Product(Long id, String name, double price, String description, Long userId) {
            this.id = id;
            this.name = name;
            this.price = price;
            this.description = description;
            this.userId = userId;
        }
    }

    // ===== AUTH =====

    // REGISTER
    @PostMapping("/auth/register")
    public ResponseEntity<?> register(@RequestBody Map<String, String> body) {
        User user = new User(
                userId.incrementAndGet(),
                body.get("email"),
                body.get("password")
        );
        users.add(user);
        return ResponseEntity.ok("User created");
    }

    // LOGIN
    @PostMapping("/auth/login")
    public ResponseEntity<?> login(@RequestBody Map<String, String> body) {
        for (User user : users) {
            if (user.email.equals(body.get("email")) &&
                user.password.equals(body.get("password"))) {

                String token = UUID.randomUUID().toString();
                tokens.put(token, user.id);

                return ResponseEntity.ok(Map.of("token", token));
            }
        }
        return ResponseEntity.status(400).body("Invalid credentials");
    }

    // ===== PRODUCT API =====

    // GET ALL
    @GetMapping("/products")
    public List<Product> getProducts() {
        return products;
    }

    // ADD PRODUCT (auth керек)
    @PostMapping("/products")
    public ResponseEntity<?> addProduct(
            @RequestHeader("Authorization") String token,
            @RequestBody Map<String, Object> body) {

        if (!tokens.containsKey(token)) {
            return ResponseEntity.status(401).body("Unauthorized");
        }

        Long userId = tokens.get(token);

        Product product = new Product(
                productId.incrementAndGet(),
                (String) body.get("name"),
                Double.parseDouble(body.get("price").toString()),
                (String) body.get("description"),
                userId
        );

        products.add(product);
        return ResponseEntity.ok(product);
    }

    // DELETE
    @DeleteMapping("/products/{id}")
    public ResponseEntity<?> deleteProduct(
            @RequestHeader("Authorization") String token,
            @PathVariable Long id) {

        if (!tokens.containsKey(token)) {
            return ResponseEntity.status(401).body("Unauthorized");
        }

        products.removeIf(p -> p.id.equals(id));
        return ResponseEntity.ok("Deleted");
    }
}
